  audioSource: {fileID: 1447395316}
  welcomeMessage: Welcome to Alphabet Sounds!
  welcomeAudio: {fileID: 8300000, guid: eccc5b58fcd38d449a17129db9c0f0c4, type: 3}
  instructionMessage: Let's learn the individual sounds of each letter in the alphabet.
  instructionAudio: {fileID: 8300000, guid: a772b65731044334c9668394e5b13c89, type: 3}
  nextOrRepeatMessage: Press Yes for the next letter, or press Repeat to hear the
    current letter again.
  nextOrRepeatAudio: {fileID: 8300000, guid: 44673807686c0c14184d58706aaca2ac, type: 3}
  completedMessage: Great job! You finished the alphabet sounds.
  completedAudio: {fileID: 8300000, guid: 452b8a930791a154b84d467197de60ea, type: 3}
  replayQuestionMessage: Do you want to repeat the alphabet sounds starting from
    A? Press Yes for repeat or No to end.
  replayQuestionAudio: {fileID: 8300000, guid: c7c03392e568b3b47be79e3a821212f7, type: 3}
  endMessage: Okay! Ending the alphabet sounds lesson. Great job!
  endAudio: {fileID: 8300000, guid: bad335c0f68d03848ad8a713122e2315, type: 3}
  alphabetEntries:
  - letter: A
    objectName: Apple
    bubbleMessage: Letter A sounds "ah". "ah, ah, Apple".
    image: {fileID: 21300000, guid: 2aef319f146bc0844a11760b06a8157b, type: 3}
    audioClip: {fileID: 8300000, guid: 08df9a11ed63c5a43b6a7f3d5be0c85a, type: 3}
