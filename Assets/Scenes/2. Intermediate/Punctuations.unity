    supportMessage: Remember period uses dots 2, 5&6. Press the dots 2, 5&6.
    supportAudio: {fileID: 8300000, guid: d67aaafec0c9346488c55e23b64d6e70, type: 3}
  - displayLabel: .
    categoryLabel: Period
    promptMessage: 'Let''s try using period in a sentence. Complete this sentence.
      "I have to go." '
    repeatMessage: 'Let''s try using period in a sentence. Complete this sentence.
      "I have to go." '
    successMessage: That's Correct. Good Job!
    wrongMessage: Wrong. Please try again.
    descriptionMessage: Also, If a sentence ends with an abbreviation, the period
      used for the abbreviation also serves as the period for the sentence. This
      is true even if the abbreviation is contained within a quotation.
    descriptionAudio: {fileID: 8300000, guid: 3147242223737714ea1629f7f9d4b45b, type: 3}
    lessonKind: 1
