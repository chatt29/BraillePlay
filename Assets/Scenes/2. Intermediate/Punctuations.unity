  welcomeMessage: Welcome to Basic Punctuations!
  letsLearnMessage: Let's Learn How to Translate Basic Punctuations in Braille!
  completedMessage: Great job! You've finished learning how to Translate Basic Punctuations
    in Braille.
  repeatQuestionMessage: You've finished learning how to Translate Basic Punctuations
    in Braille. Do you want to repeat again? Press R to repeat or next to finish.
  lessons:
  - displayLabel: .
    categoryLabel: Period
    promptMessage: 'This is Period ".". Press the Dots 2, 5&6. '
    repeatMessage: 'This is Period ".". Press the Dots 2, 5&6. '
    successMessage: That's Correct. That's how you type "Period" in Braille.
    wrongMessage: Wrong. Please try again.
    descriptionMessage: The period is perhaps the easiest punctuation mark to master.
      It ends a sentence.
    descriptionAudio: {fileID: 8300000, guid: ff46780778b946c4db4e1e66f06055f8, type: 3}
    lessonKind: 0
    dots: 020000000500000006000000
