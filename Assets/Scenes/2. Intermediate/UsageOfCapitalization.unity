--- !u!114 &1586095482
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1586095473}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f7c1514bb51c05d46b23edef8384a4ec, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::UsageOfCapitalization_Script
  bubbleText: {fileID: 1257937990}
  translationText: {fileID: 2077778574}
  resultText: {fileID: 176604274}
  stageTypeText: {fileID: 186052603}
  lessonImage: {fileID: 286661654}
  audioSource: {fileID: 1586095478}
  dot6Image: {fileID: 21300000, guid: 02136a454370e16498891dca3ded243d, type: 3}
  startLessonLine:
    message: Welcome to Usage of Capitalization. In this lesson, you will learn how
      to capitalize a letter, a word, and a sentence.
    audioClip: {fileID: 8300000, guid: 9742a791078ba1d4cae85d7568d8cee3, type: 3}
  letterStageIntroLine:
    message: "First, let\u2019s learn how to capitalize one letter."
    audioClip: {fileID: 8300000, guid: c9fff2f713ab23145ba3e0d95589af65, type: 3}
  wordStageIntroLine:
    message: "Now let\u2019s learn how to capitalize one word."
    audioClip: {fileID: 8300000, guid: 62179a82510809b409935d35d5c483ad, type: 3}
  sentenceStageIntroLine:
    message: "Now let\u2019s learn how to capitalize a full sentence."
    audioClip: {fileID: 8300000, guid: 2295d17f5f144e1499a64b3db55efb7a, type: 3}
  letterStagePromptLine:
    message: Press dot 6 one time. Dot 6 tells Braille that the next letter should
      be capitalized.
    audioClip: {fileID: 8300000, guid: b6eb1ee4e11e7bd448fae90ed4b42bf9, type: 3}
  wordStagePromptLine:
    message: Press dot 6 two times. Two capital signs tell Braille that the next
      word should be capitalized.
    audioClip: {fileID: 8300000, guid: 4b7714a170a399e40a541a888deca18a, type: 3}
  sentenceStagePromptLine:
    message: Press dot 6 three times. Three capital signs tell Braille that the whole
      sentence should be capitalized.
    audioClip: {fileID: 8300000, guid: 69c689bda54d39f428bffd702df5b3cc, type: 3}
  wordStageSecondPressLine:
    message: Good. Press dot 6 one more time to capitalize the whole word.
    audioClip: {fileID: 8300000, guid: 52b70c5e5ca63a74d98eb09749b917c1, type: 3}
  sentenceStageSecondPressLine:
    message: Good. Press dot 6 again.
    audioClip: {fileID: 8300000, guid: 58a1f9ac358c63a4bbbbd909ce410ff6, type: 3}
  sentenceStageThirdPressLine:
    message: Great. Press dot 6 one more time to capitalize the whole sentence.
    audioClip: {fileID: 8300000, guid: 0f7c54f53bd567d4cbb9993688304780, type: 3}
  letterTypingPromptLine:
    message: 'Now type the sentence: the cat is cute. The first letter is capital
      T.'
    audioClip: {fileID: 8300000, guid: 37eea4cf23be0ab4e853b10a6ac46c77, type: 3}
  wordTypingPromptLine:
    message: 'Now type the sentence: the cat is cute. The first word is capitalized:
      capital T, capital H, capital E.'
    audioClip: {fileID: 8300000, guid: 830dac1f5c647244cb1cfac77bfd3f72, type: 3}
  sentenceTypingPromptLine:
    message: 'Now type the sentence: the cat is cute. Every letter is capitalized.
      In a sentence, the first word always starts with a capital letter.'
    audioClip: {fileID: 8300000, guid: 477e1602d4dc5ab4b81c94f24d4bedc1, type: 3}
  wrongLetterStageLine:
    message: That is not correct. To capitalize one letter, press dot 6 one time.
    audioClip: {fileID: 8300000, guid: 7ce48777b56806f469e402be44206cf8, type: 3}
  wrongWordStageLine:
    message: That is not correct. To capitalize one word, press dot 6 two times.
    audioClip: {fileID: 8300000, guid: fd0021c471e66674bab141e5d6526174, type: 3}
  wrongSentenceStageLine:
    message: That is not correct. To capitalize a full sentence, press dot 6 three
      times.
    audioClip: {fileID: 8300000, guid: 5b7fa2d1549616b4388bf667122c708c, type: 3}
  wrongTypingLine:
    message: That is not correct. Try typing the sentence again.
    audioClip: {fileID: 8300000, guid: 9ceb30e0d43f6b64db0a65bc928c9435, type: 3}
  letterStageSuccessLine:
    message: Great job. You capitalized one letter. The sentence starts with capital
      T.
    audioClip: {fileID: 8300000, guid: e815bd59af582f84ba6f78f3ad141dbd, type: 3}
  wordStageSuccessLine:
    message: Great job. You capitalized the whole word THE.
    audioClip: {fileID: 8300000, guid: 53f1a53377acd454885edca9972abb6a, type: 3}
  sentenceStageSuccessLine:
    message: Excellent. You capitalized the full sentence. Remember, in a sentence,
      the first word always starts with a capital letter.
    audioClip: {fileID: 8300000, guid: 7c257af464e85394fb53d34d2eeae721, type: 3}
  stageDecisionLine:
    message: Do you want to continue to the next part? Press Yes to continue, or
      No to repeat this part.
    audioClip: {fileID: 8300000, guid: 021add58bee5ced4b8cf6693cb849f77, type: 3}
  completedLessonLine:
    message: Great job. You finished the Usage of Capitalization lesson.
    audioClip: {fileID: 8300000, guid: f85c555679370c8448731d8258f4bcf4, type: 3}
  restartOrNextLessonLine:
    message: Do you want to repeat this lesson? Press Yes to repeat, or No to go
      to the next lesson.
    audioClip: {fileID: 8300000, guid: c7f02ff1d272c5c4ab70b4f188c849d6, type: 3}
  endLessonLine:
    message: Okay. Ending the capitalization lesson. Great job.
    audioClip: {fileID: 8300000, guid: 62dba89b58130434fa64cc5244e6f174, type: 3}
  baseSentence: the cat is cute.
  letterSentence: The cat is cute.
  wordSentence: THE cat is cute.
  sentenceSentence: THE CAT IS CUTE.
  playOnStart: 1
  extraWaitAfterAudio: 0.15
  nextLessonSceneName: 
